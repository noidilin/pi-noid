{
	"name": "@noid/pi-extensions",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./packages/bar/index.ts",
			"./packages/skill-manager/index.ts",
			"./packages/bar-config/index.ts",
			"./packages/matt-ralph/index.ts"
		]
	},
	"scripts": {
		"check": "biome check --write --error-on-warnings . && tsc --noEmit -p tsconfig.base.json",
		"test": "vitest run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@earendil-works/pi-coding-agent": "^0.77.0",
		"@earendil-works/pi-tui": "^0.77.0",
		"@types/node": "^22.0.0",
		"typebox": "^1.1.34",
		"typescript": "^6.0.0",
		"vitest": "^4.0.0"
	}
}
